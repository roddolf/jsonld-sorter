{
  "name": "jsonld-sorter",
  "version": "0.2.4",
  "description": "Sorter of JSON-LD data",
  "engines": {
    "node": ">=20"
  },
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": "dist/cli.js",
  "scripts": {
    "build": "npm-run-all build:*",
    "build:src": "tsup",
    "build:docs": "typedoc src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "release": "standard-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roddolf/jsonld-sort.git"
  },
  "keywords": [
    "jsonld",
    "sorter"
  ],
  "author": "Rodolfo Aguirre <aguirreg.rodolfo@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/roddolf/jsonld-sort/issues"
  },
  "homepage": "https://github.com/roddolf/jsonld-sort#readme",
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/jest": "^30.0.0",
    "@types/yargs": "^17.0.13",
    "jest": "^30.3.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.0.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.18",
    "typescript": "~6.0"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "files": [
    "dist"
  ]
}
